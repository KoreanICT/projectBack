<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.ictedu.projectBack.dao.OrderDao">
	<insert id="addOrderForm" parameterType="ofvo">
		INSERT INTO ORDERFORM (OFNUM,ONAME,OADDR,OPHONE,OFDATE,MEMBERMNUM,OIMG,OFCOMPANY)
		VALUES (orderform_seq.NEXTVAL, #{oname}, #{oaddr}, #{ophone}, SYSDATE, #{membernum}, #{oimg}, #{ofcompany})
	</insert>
	<insert id="addOrderItem" parameterType="java.util.List">
		<!-- 현재 시퀀스 값 가져오기 -->
		<selectKey keyProperty="id" resultType="int" order="BEFORE">
			SELECT orderform_seq.currVal FROM dual
		</selectKey>
		<foreach collection="list" item="item" separator=" " open="insert all"
			close="select * from dual">
			INTO ORDERITEM (OINUM,OINAME,OIPUBLISHER,OIPRICE,OISUMPRICE,OIAMOUNT,OFNUM)
			VALUES (orderitem_seq.NEXTVAL, #{item.oiname}, #{item.oipublisher}, #{item.oiprice}, #{item.oisumprice}, #{item.oiamount}, #{id})
		</foreach>
	</insert>
</mapper>