<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.ictedu.projectBack.dao.ReplyDao">

	<insert id="addComment" parameterType="reply">
	insert into reply values(reply_seq.nextVal,
	#{rcode},#{rwriter},
	#{rcontent}, sysdate,2)
	</insert>

	<select id="listComment" resultType="reply" parameterType="int">
	select * from reply where rcode=#{rnum} order by 1 desc 
	</select>
</mapper>